============================================
# Nextcloud + MariaDB + Vaultwarden + Caddy
# Arquivo de exemplo - Copie para .env e preencha
# ============================================

# --- Banco de dados MariaDB (usuário nextcloud) ---
# Use uma senha forte, diferente da root
NC_DB_PASSWORD=TZLPo5IB97l3fTKa8a5ISWtakkM3ks8Zbwm9EpACa7k=

# --- Senha do usuário root do MariaDB ---
# Mantenha em local seguro, é a senha mestra do banco
NC_ROOT_PASSWORD=0LxuT1co8y4HJ6DhTg+LAnwdHxh7mTNyvJ27rVqYM+0=

# --- CONFIGURAÇÃO DE TUNELAMENTO CLOUDFLARE ---
#Obtenha o token em:
# 1. https://dash.cloudflare.com/ -> networking > Tunnels.
# 2. Em tunell-name dê um nome para seu tunel.
# 3. Escolha opção: Docker em Setup Environment
# 4. Irá gerar algo como docker run cloudflare/cloudflared:latest tunnel --no-autoupdate run --token eyJhIjo...
# 5. Tudo depois do --token é o seu TOKEN que deve ficar acima em CLOUDFLARE_TUNNEL_TOKEN=eyJhIjo...
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjo...



# ============================================
# Instruções de segurança:
# 1. Gere senhas fortes (ex: openssl rand -base64 32)
# 2. Após criar o .env real, execute: chmod 600 .env
# 3. NUNCA comite o .env real no versionamento
# 4. Mantenha o .env.example no repositório (sem valores reais)
# ============================================
