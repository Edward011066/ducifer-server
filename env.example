# ==============================================================================
# PROJETO: DUCIFER SERVER (Nextcloud + MariaDB + Vaultwarden + Redis + Tunnel)
# Instruções: Copie este arquivo para um novo chamado '.env' e preencha os valores.
# Comando: cp .env.example .env
# ==============================================================================

# --- BANCO DE DADOS (MariaDB) ---
# NC_DB_PASSWORD: Senha do usuário 'nextcloud' para acessar o banco.
# NC_ROOT_PASSWORD: Senha mestra do banco de dados.
NC_DB_PASSWORD=gerar_senha_forte_aqui
NC_ROOT_PASSWORD=gerar_senha_mestra_aqui

# --- CONFIGURAÇÃO DE ACESSO EXTERNO (Cloudflare Tunnel) ---
# Obtenha o token no painel Cloudflare Zero Trust:
# 1. Networks -> Tunnels -> Create a Tunnel
# 2. Escolha 'Docker' no setup e copie apenas o código após '--token'
CLOUDFLARE_TUNNEL_TOKEN=seu_token_aqui

# --- CONFIGURAÇÃO DO NEXTCLOUD (Opcional, mas recomendado) ---
# Defina seu domínio aqui para evitar erros de 'Trusted Domains'
NEXTCLOUD_DOMAIN=nextcloud.seu-dominio.com

# --- CONFIGURAÇÃO DE LOCALIZAÇÃO ---
TZ=America/Sao_Paulo

# ==============================================================================
# DICAS DE SEGURANÇA:
# 1. Gere senhas aleatórias: openssl rand -base64 32
# 2. Proteja seu arquivo .env: chmod 600 .env
# 3. NUNCA envie seu arquivo .env real para o GitHub.
# ==============================================================================
